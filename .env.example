# =============================================================================
# AI Lab — Environment Variables
# Copy this file to .env and adjust values as needed
# =============================================================================

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_MODEL=nemotron-3-super:cloud
CODER_MODEL=nemotron-3-super:cloud
EMBEDDING_MODEL=nomic-embed-text

# PostgreSQL
POSTGRES_USER=ailab
POSTGRES_PASSWORD=ailab
POSTGRES_DB=ailab
POSTGRES_URL=postgresql+asyncpg://ailab:ailab@postgres:5432/ailab

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# Limits
MAX_UPLOAD_SIZE_MB=50
AGENT_TIMEOUT_SECONDS=120
MEMORY_TTL_SECONDS=7200
RAG_DEFAULT_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Goal-Oriented OS (v2)
APPROVAL_TIMEOUT_SECONDS=300
GOAL_MAX_CONCURRENT=3
# Set to any host directory you want file-watched. Mounted at /app/watched inside the container.
WATCHED_PATHS_ROOT=./data
